PROGRAM=Checkers
OBJECTS=checkers.o game.o game_display.o game_interaction.o game_checkers.o menu.o net_menu.o main-osx.o sprite.o scenegraph-gl.o texture.o input.o text.o gui.o text_input.o game_net.o CheckersView.o
LDFLAGS=-framework Cocoa -framework OpenGL
CFLAGS=	-Wall -O2 -std=gnu99 $(CFLAGS_BONJOUR$(USE_BONJOUR))
CFLAGS_BONJOUR=	-DUSE_BONJOUR

Checkers.app: $(PROGRAM)
	mkdir -p $@/Contents/{MacOS,Resources}
	cp cocoa/Info.plist $@/Contents
	cp -r cocoa/English.lproj assets/textures $@/Contents/Resources
	cp $< $@/Contents/MacOS

$(PROGRAM): $(OBJECTS)
	$(CC) -o $@ $(OBJECTS) $(LDFLAGS)

clean:
	rm -f $(PROGRAM) $(OBJECTS)
